# ===================================
# MedAsset - Environment Variables
# ===================================
# Copy file này thành .env và điền giá trị phù hợp
# cp .env.example .env

# --- NextAuth ---
# Secret key để mã hóa JWT token (bắt buộc)
# Tạo secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here

# URL gốc của ứng dụng (bắt buộc)
NEXTAUTH_URL=http://localhost:3000

# --- Database ---
# SQLite: file database nằm trong thư mục prisma/
# Không cần cài đặt database server riêng
DATABASE_URL="file:./dev.db"
